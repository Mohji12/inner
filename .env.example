# Frontend (Vite). Copy to `.env` or `.env.local` and restart `npm run dev`.
#
# Mode A — same-origin + proxy (simplest for httpOnly refresh cookies in dev):
#   Leave empty. Browser calls `/api/v1/...` on the Vite origin; vite.config.ts
#   proxies `/api` → http://127.0.0.1:8000
#   VITE_API_URL=
#
# Mode B — call the API origin directly (production or when you want an explicit URL):
#   Use the same host style as the page when testing cookies (e.g. if the app is
#   http://127.0.0.1:8080, use 127.0.0.1 for the API below; avoid mixing localhost vs 127.0.0.1).
#   VITE_API_URL=http://127.0.0.1:8000
# Amplify / staging backend (no path; client appends /api/v1):
#   VITE_API_URL=https://inner.krintix.in

VITE_API_URL=

# Google OAuth client ID for Google Sign-In button.
# Leave empty to hide Google Sign-In in login page.
VITE_GOOGLE_CLIENT_ID=

# Optional: note for Mollie return URL — must match backend MOLLIE_REDIRECT_BASE_URL (same origin as this dev server).
# Example: http://localhost:8081 → backend/.env MOLLIE_REDIRECT_BASE_URL=http://localhost:8081
