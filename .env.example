# Frontend (Vite). Copy to `.env` or `.env.local` and restart `npm run dev`.
#
# Mode A — remote API (staging / production backend at inner.krintix.in):
VITE_API_URL=https://inner.krintix.in
#
# Mode B — local backend via Vite proxy (same-origin `/api` → http://127.0.0.1:8000):
#   Leave VITE_API_URL empty and run uvicorn on port 8000.
#   VITE_API_URL=
#
# Mode C — call local API directly (no proxy):
#VITE_API_URL=http://127.0.0.1:8000

# Google OAuth client ID for Google Sign-In button.
# Leave empty to hide Google Sign-In in login page.
VITE_GOOGLE_CLIENT_ID=

# Optional homepage background music. Default: public/images/morning-currencies.mp3
# VITE_HOME_MUSIC_URL=/images/morning-currencies.mp3

# Mollie return URL must match backend MOLLIE_REDIRECT_BASE_URL (same origin as this dev server).
# Example: http://localhost:8081 → backend/.env MOLLIE_REDIRECT_BASE_URL=http://localhost:8081