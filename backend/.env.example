# Copy to `.env` and fill in values. Do not commit `.env`.

DB_HOST=localhost
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your_password_here
DB_NAME=therapy

JWT_SECRET_KEY=change-me-long-random-access-secret
JWT_REFRESH_SECRET_KEY=change-me-long-random-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated origins for browser clients (add your Amplify / production SPA origins)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173,https://mijnlevenspad.com,https://www.mijnlevenspad.com,https://staging.dutgt85z7f3h6.amplifyapp.com,https://inner.krintix.in

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.example.com

USER_REFRESH_COOKIE=ipd_refresh_user
MENTOR_REFRESH_COOKIE=ipd_refresh_mentor
ADMIN_REFRESH_COOKIE=ipd_refresh_admin

# Dev-only: after running migrations/004_admin.sql, default admin is:
#   Email: admin@example.com
#   Password: Admin123!
# Change or remove this account in production.

# Email (ZeptoMail SMTP) — required to deliver registration OTP in production
# Example (smtp.zeptomail.in): SMTP_USER is usually "emailapikey"; SMTP_PASSWORD is the API key
# from ZeptoMail. SMTP_FROM_EMAIL must be a verified sender (e.g. info@yourdomain.com).
# Leave SMTP_HOST empty for local dev: OTP is returned as dev_verification_code and logged.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=emailapikey
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Mijn Levenspad
SMTP_USE_TLS=true

OTP_EXPIRE_MINUTES=15
OTP_MAX_ATTEMPTS=5
# Optional extra secret for OTP hashing (defaults to JWT_SECRET_KEY if empty)
OTP_PEPPER=

# Public mentor directory: set true only on local dev to list status=pending mentors (default directory is active+approved only)
PUBLIC_MENTOR_LIST_INCLUDE_PENDING=false

# LiveKit (https://cloud.livekit.io) — browser voice/video for chat sessions. Leave empty to disable POST /chat/sessions/{id}/call/token.
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# Optional: outbound SIP trunk id from LiveKit (phone dial-out to peer profile number)
# LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# Optional: E.164 caller ID (your Twilio/Telnyx number). Often required if trunk uses * or multiple numbers.
# LIVEKIT_SIP_CALLER_ID=

# ----- Mollie (Dashboard setup checklist — live vs test keys in Mollie) -----
# 1) Organization API key (platform checkout): Developers → API keys → copy live or test key.
# 2) OAuth / Connect app: Developers → OAuth / Connect → create app.
#    Register redirect URI EXACTLY (scheme, path, no stray slash):
#      https://inner.krintix.in/api/v1/marketplace/connect/callback
#    Enable scopes your code requests: onboarding.read, organizations.read, profiles.read, balances.read
#    (balances.read is used for settlement balance checks before payout execution.)
# 3) Payment webhooks: Organization settings → Webhooks → URL:
#      https://inner.krintix.in/api/v1/payments/webhook
#    Set the same secret in MOLLIE_WEBHOOK_SECRET below.
#
# MOLLIE_API_KEY=test_...
# MOLLIE_CLIENT_ID=app_...
# MOLLIE_CLIENT_SECRET=
# MOLLIE_CONNECT_REDIRECT_URI=https://inner.krintix.in/api/v1/marketplace/connect/callback
#
# Where users return after Mollie checkout (frontend origin only — no path, no trailing slash).
# Must match the URL in the browser when you run the SPA.
#
# Local dev (default vite port 8080, or e.g. npx vite --port 8081):
#   MOLLIE_REDIRECT_BASE_URL=http://localhost:8081
#
# Staging SPA (Amplify):
#   MOLLIE_REDIRECT_BASE_URL=https://staging.dutgt85z7f3h6.amplifyapp.com
#
# Production SPA:
#   MOLLIE_REDIRECT_BASE_URL=https://inner.krintix.in
#
# Resulting redirect after booking payment:
#   {MOLLIE_REDIRECT_BASE_URL}/user/appointments?bookingId={booking_id}
MOLLIE_REDIRECT_BASE_URL=http://localhost:8081
# Public HTTPS origin of THIS API only (webhook POST target). NOT the Amplify hostname unless API is there.
# MOLLIE_WEBHOOK_BASE_URL=https://inner.krintix.in
# MOLLIE_WEBHOOK_SECRET=

# Marketplace wallet/commission/payout controls
# MARKETPLACE_DEFAULT_COMMISSION_PERCENT=30
# MARKETPLACE_DEFAULT_COACH_SHARE_PERCENT=70
# Metered chat: optional separate tax % (0 = tax within coach share); one-time EUR session fee
# CHAT_SESSION_TAX_PERCENT=0
# CHAT_SESSION_TRANSACTION_FEE_EUR=0.50
# MARKETPLACE_MIN_WITHDRAWAL_AMOUNT=10.00
# MARKETPLACE_PAYOUT_COOLDOWN_HOURS=24
# MARKETPLACE_HOLD_EXPIRY_MINUTES=120
# MARKETPLACE_BILLING_TICK_SECONDS=10

# Async queue / Celery (worker must share REDIS_URL)
# REDIS_URL=redis://localhost:6379/0
# Optional: persist task results (e.g. Flower). Leave unset to disable — avoids Redis "result store" reconnect errors in uvicorn-only dev.
# CELERY_RESULT_BACKEND_URL=redis://localhost:6379/1

# Allowed checkout currencies (converted from EUR base tiers/fees): comma-separated ISO 4217 codes. EUR is always kept.
# PAYMENT_CHECKOUT_CURRENCIES=EUR,USD,GBP
# ECB-style FX via Frankfurter (override full URL if needed). Used when checkout currency ≠ EUR.
# FX_RATES_URL=https://api.frankfurter.app/latest
# FX_RATES_CACHE_TTL_SECONDS=900
# FX_RATES_HTTP_TIMEOUT_SECONDS=10

# Mentor onboarding checkout: set MENTOR_ONBOARDING_FEE_EUR=0 for free coach registration.
# Example paid onboarding: FEE=70, ADD_PERCENT=0
# MENTOR_ONBOARDING_FEE_EUR=0
# MENTOR_ONBOARDING_FEE_ADD_PERCENT=0
# MENTOR_ONBOARDING_INSTALLMENT_COUNT=2
# Auto-created onboarding waiver promo (100% off coach registration fee). Set empty to disable seed.
# MENTOR_ONBOARDING_PROMO_SEED_CODE=COACHFREE

# Session tiers (EUR per minute × 5/10/20/30). Bootstrap fills platform_pricing when all tiers are 0.
# SESSION_PRICE_EUR_PER_MINUTE=0.90

# Stripe Settings
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CURRENCY=EUR

# Cloudinary — mentor/user profile & banner images (HTTPS URLs stored in DB). If any value is empty, uploads use local `./uploads` instead.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
